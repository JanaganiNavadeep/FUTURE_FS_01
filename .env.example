OWNER_PHONE=+91-9963363474
OWNER_LINKEDIN=https://linkedin.com/in/janagani-navadeep
OWNER_GITHUB=https://github.com/JanaganiNavadeep

# ============================================
# Email Configuration
# ============================================
MAIL_DRIVER=php_mail
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourportfolio.com
MAIL_FROM_NAME=Janagani Navadeep

# SMTP Alternative (uncomment to use)
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_ENCRYPTION=tls

# ============================================
# Security Configuration
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_KEY=your_secret_key_here_change_this
CORS_ALLOWED_ORIGINS=*
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=10

# ============================================
# Features
# ============================================
ENABLE_CONTACT_FORM=true
ENABLE_ANALYTICS=true
ENABLE_COMMENTS=false
ENABLE_ADMIN_PANEL=true
MAINTENANCE_MODE=false

# ============================================
# Application Settings
# ============================================
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en_IN
APP_NAME=Janagani Navadeep Portfolio
APP_URL=http://localhost/portfolio

# Production URL
# APP_URL=https://yourdomain.com/portfolio

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=weekly
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ============================================
# Session Configuration
# ============================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_MAX_SIZE=10000000
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=./uploads

# ============================================
# Cache Configuration
# ============================================
CACHE_DRIVER=file
CACHE_TTL=3600

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_PATH=./logs
LOG_MAX_SIZE=10485760

# ============================================
# Analytics & Tracking
# ============================================
GOOGLE_ANALYTICS_ID=
TRACK_VISITOR_IP=false
TRACK_REFERRER=true

# ============================================
# Social Media Links
# ============================================
TWITTER_URL=
INSTAGRAM_URL=
FACEBOOK_URL=
YOUTUBE_URL=
PORTFOLIO_URL=

# ============================================
# Theme Configuration
# ============================================
THEME_COLOR_PRIMARY=#7c3aed
THEME_COLOR_SECONDARY=#06b6d4
THEME_COLOR_ACCENT=#ec4899
DARK_MODE=true

# ============================================
# API Configuration
# ============================================
API_VERSION=v1
API_RATE_LIMIT=100
API_TIMEOUT=30

# ============================================
# Development Tools
# ============================================
ENABLE_DEBUG_BAR=false
ENABLE_PROFILER=false
ENABLE_QUERY_LOG=false

# ============================================
# Instructions
# ============================================
# 1. Copy this file to .env
# 2. Update all values with your settings
# 3. Keep this file secure (.env in .gitignore)
# 4. Never commit sensitive data to version control
# 5. For production, use environment variables instead
