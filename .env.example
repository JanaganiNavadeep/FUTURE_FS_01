DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=portfolio_janagani
DB_CHARSET=utf8mb4

# ============================================
# Personal Information
# ============================================
OWNER_ID=1
OWNER_FIRST_NAME=Janagani
OWNER_LAST_NAME=Navadeep
